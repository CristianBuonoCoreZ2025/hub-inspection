# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temporary scripts (debug/check/fix one-off scripts)
scripts/debug-*.cjs
scripts/check-*.cjs
scripts/fix-*.cjs
scripts/test-*.cjs
scripts/apply-migration-*.cjs
scripts/audit-*.cjs
scripts/migrate-*.cjs
scripts/recreate-*.cjs
scripts/retrack-*.cjs
scripts/reload-*.cjs
scripts/track-*.cjs
scripts/scrape-*.cjs
scripts/list-*.cjs
scripts/screenshot*
scripts/hasura-*.ts
scripts/setup-hasura-*.ts

# binary/temp files
*.traineddata
hasura-meta.json
tmp-*
tmp_*

# screenshots
screenshots/

# database dumps
migrations/supabase_data.sql
migrations/supabase_schema.sql
