# ============================================================
# Hub Inspections — Variables de Entorno
# ============================================================
# Copia este archivo como .env.local y completa los valores.

# --- Nhost (requerido) ---
# Opción A: Subdomain + Region (Nhost Cloud)
NEXT_PUBLIC_NHOST_SUBDOMAIN=tu-subdomain
NEXT_PUBLIC_NHOST_REGION=eu-central-1

# Opción B: URLs individuales (local o custom)
NEXT_PUBLIC_NHOST_AUTH_URL=https://auth.tfejikhjszwowlvsupb.nhost.run
NEXT_PUBLIC_NHOST_GRAPHQL_URL=https://graphql.tfejikhjszwowlvsupb.nhost.run/v1
NEXT_PUBLIC_NHOST_STORAGE_URL=https://storage.tfejikhjszwowlvsupb.nhost.run
# NEXT_PUBLIC_NHOST_FUNCTIONS_URL=https://functions.tu-proyecto.nhost.run

# --- PostgreSQL / Migraciones (requerido para db:push) ---
# Connection string de tu base de datos (Nhost Console → Settings → Database)
DATABASE_URL="postgres://user:password@host:port/database"

# --- Admin (solo server-side) ---
# NHOST_ADMIN_SECRET=tu-admin-secret
