# ============================================================
# Hub Inspections — Variables de Entorno
# ============================================================
# Copia este archivo como .env.local y completa los valores.

# --- Nhost (requerido) ---
# Opción A: Subdomain + Region (Nhost Cloud)
NEXT_PUBLIC_NHOST_SUBDOMAIN=tu-subdomain
NEXT_PUBLIC_NHOST_REGION=eu-central-1

# Opción B: URLs individuales (local o custom)
# IMPORTANTE: Formato Nhost Cloud = https://<subdomain>.<service>.<region>.nhost.run
NEXT_PUBLIC_NHOST_AUTH_URL=https://tfejikhjszwowlvsupb.auth.eu-central-1.nhost.run
NEXT_PUBLIC_NHOST_GRAPHQL_URL=https://tfejikhjszwowlvsxupb.graphql.eu-central-1.nhost.run/v1
NEXT_PUBLIC_NHOST_STORAGE_URL=https://tfejikhjszwowlvsxupb.storage.eu-central-1.nhost.run
# NEXT_PUBLIC_NHOST_FUNCTIONS_URL=https://tfejikhjszwowlvsxupb.functions.eu-central-1.nhost.run

# --- PostgreSQL / Migraciones (requerido para db:push) ---
# Connection string de tu base de datos (Nhost Console → Settings → Database)
DATABASE_URL="postgres://user:password@host:port/database"

# --- Admin (solo server-side) ---
# NHOST_ADMIN_SECRET=tu-admin-secret

# --- Cloudflare R2 (storage de archivos del siniestro) ---
# Requerido para subir/descargar documentos y fotos en producción (Vercel).
# Dashboard de Cloudflare → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=tu-account-id
R2_ACCESS_KEY_ID=tu-access-key-id
R2_SECRET_ACCESS_KEY=tu-secret-access-key
R2_BUCKET_NAME=tu-bucket-name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# --- Supabase (auth + storage de evidencias) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
