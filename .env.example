# ============================================================
# Hub Inspections — Variables de Entorno
# ============================================================
# Copia este archivo como .env.local y completa los valores.

# --- Supabase (auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- PostgreSQL / Migraciones (requerido para db:push) ---
# Connection string de tu base de datos (Supabase Console → Settings → Database)
DATABASE_URL="postgres://user:password@host:port/database"

# --- Cloudflare R2 (storage de TODOS los archivos) ---
# Requerido para subir/descargar documentos, fotos, firmas, croquis, logos.
# Dashboard de Cloudflare → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=tu-account-id
R2_ACCESS_KEY_ID=tu-access-key-id
R2_SECRET_ACCESS_KEY=tu-secret-access-key
R2_BUCKET_NAME=tu-bucket-name
R2_PUBLIC_URL=https://pub-xxx.r2.dev
