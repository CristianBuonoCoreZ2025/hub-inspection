# ============================================================
# Hub Inspections — Variables de Entorno
# ============================================================
# Copia este archivo como .env.local y completa los valores.

# --- Supabase (auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- PostgreSQL / Migraciones (requerido para db:push) ---
# Connection string de tu base de datos (Supabase Console → Settings → Database)
DATABASE_URL="postgres://user:password@host:port/database"

# --- Cloudflare R2 (storage de TODOS los archivos) ---
# Requerido para subir/descargar documentos, fotos, firmas, croquis, logos.
# Dashboard de Cloudflare → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=tu-account-id
R2_ACCESS_KEY_ID=tu-access-key-id
R2_SECRET_ACCESS_KEY=tu-secret-access-key
R2_BUCKET_NAME=tu-bucket-name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# --- OpenRouter (IA: vision, documentos, retail) ---
# Obtener keys en https://openrouter.ai/keys
# Se pueden poner múltiples keys separadas por coma (rotación/failover)
OPENROUTER_API_KEY=sk-or-v1-tu-key-1,sk-or-v1-tu-key-2
OPENROUTER_HTTP_REFERER=http://localhost:3000

# Estrategia de visión (fotos): prioridad free → pago
OPENROUTER_VISION_MODEL_FREE="qwen/qwen-2.5-vl-72b-instruct:free,google/gemma-4-31b-it:free,nvidia/nemotron-nano-12b-v2-vl:free,openrouter/free,moonshotai/kimi-k2.6:free"
OPENROUTER_VISION_MODEL="openai/gpt-4o-mini,openai/gpt-4o"

# Estrategia de documentos (PDF/OCR): prioridad free → pago
OPENROUTER_DOCUMENT_MODEL_FREE="google/gemma-4-31b-it:free,qwen/qwen2.5-vl-72b-instruct:free,google/gemini-2.0-flash-exp:free,nvidia/nemotron-nano-12b-v2-vl:free,moonshotai/kimi-k2.6:free,openrouter/free"
OPENROUTER_DOCUMENT_MODEL="openai/gpt-4o-mini,deepseek/deepseek-chat,anthropic/claude-3.5-haiku,google/gemini-2.0-flash-001"

# Provider de visión: solo OpenRouter
VISION_PROVIDER=openrouter
VISION_CHAIN=openrouter_free,openrouter

# Google Gemini (backup)
GEMINI_API_KEY=tu-gemini-api-key

# --- Retail IA (presupuestos post-inspección) ---
OPENROUTER_RETAIL_MODEL_FREE=openrouter/free
RETAIL_AI_ALLOW_PAID_FALLBACK=0
