/**
 * Screenshot tool — abre el navegador, hace login via UI, navega a una página
 * y toma screenshots + extrae estilos computados.
 *
 * Uso:
 *   pnpm tsx scripts/screenshot.ts <url-path> [output-name]
 *
 * Requiere .env.local con SCREENSHOT_EMAIL y SCREENSHOT_PASSWORD
 */

import dotenv from "dotenv";
import { resolve } from "path";
import { mkdirSync, writeFileSync } from "fs";

dotenv.config({ path: resolve(process.cwd(), ".env.local") });

const email = process.env.SCREENSHOT_EMAIL;
const password = process.env.SCREENSHOT_PASSWORD;

if (!email || !password) {
  console.error("Faltan SCREENSHOT_EMAIL y SCREENSHOT_PASSWORD en .env.local");
  process.exit(1);
}

const targetPath = process.argv[2] || "/dashboard";
const outputName = process.argv[3] || "screenshot";
const baseUrl = "http://localhost:3000";
const fullUrl = `${baseUrl}${targetPath}`;

const outDir = resolve(process.cwd(), "screenshots");
mkdirSync(outDir, { recursive: true });

async function main() {
  const { chromium } = await import("playwright");
  const browser = await chromium.launch({ headless: true });
  const context = await browser.newContext({
    viewport: { width: 1440, height: 900 },
    deviceScaleFactor: 2,
  });
  const page = await context.newPage();

  // 1. Ir a la página de login
  console.log("🔐 Navegando a login...");
  await page.goto(`${baseUrl}/login`, { waitUntil: "networkidle", timeout: 30000 });
  await page.waitForTimeout(2000);

  // 2. Llenar el formulario de login
  // Buscar los inputs de email y password
  const emailInput = page.locator('input[type="email"], input[name="email"], input[placeholder*="mail" i]').first();
  const passwordInput = page.locator('input[type="password"], input[name="password"]').first();

  await emailInput.fill(email);
  await passwordInput.fill(password);

  // Buscar el botón de submit
  const submitButton = page.locator('button[type="submit"], button:has-text("Iniciar"), button:has-text("Entrar"), button:has-text("Login")').first();
  await submitButton.click();

  // 3. Esperar a que redirija al dashboard
  console.log("⏳ Esperando login...");
  await page.waitForURL("**/dashboard**", { timeout: 15000 }).catch(() => {
    console.log("⚠ No redirigió a /dashboard, intentando navegar manualmente...");
  });
  await page.waitForTimeout(2000);

  // 4. Navegar a la página objetivo
  console.log(`🌐 Navegando a ${fullUrl}...`);
  await page.goto(fullUrl, { waitUntil: "networkidle", timeout: 30000 });
  await page.waitForTimeout(4000);

  // 5. Screenshot full page
  const screenshotPath = resolve(outDir, `${outputName}.png`);
  await page.screenshot({ path: screenshotPath, fullPage: true });
  console.log(`📸 Screenshot: ${screenshotPath}`);

  // 6. Screenshot del viewport
  const viewportPath = resolve(outDir, `${outputName}-viewport.png`);
  await page.screenshot({ path: viewportPath, fullPage: false });
  console.log(`📸 Viewport: ${viewportPath}`);

  // 7. Extraer estilos computados de elementos clave
  const styleInfo = await page.evaluate(() => {
    const results: Array<{
      selector: string;
      tag: string;
      text: string;
      rect: { x: number; y: number; width: number; height: number };
      styles: Record<string, string>;
    }> = [];

    const selectors = [
      "section.app-panel",
      ".rounded-xl",
      "input[type='number']",
      "button.app-badge",
      "h3.app-section-title",
      "[class*='border-sky']",
      "[class*='border-violet']",
      "[class*='border-emerald']",
      ".grid.grid-cols-3",
      "label",
      ".app-page-title",
    ];

    const seen = new Set<string>();
    for (const sel of selectors) {
      const els = document.querySelectorAll(sel);
      els.forEach((el, i) => {
        const rect = el.getBoundingClientRect();
        if (rect.width === 0 || rect.height === 0) return;
        const key = `${sel}-${i}`;
        if (seen.has(key)) return;
        seen.add(key);

        const computed = window.getComputedStyle(el);
        results.push({
          selector: `${sel}[${i}]`,
          tag: el.tagName,
          text: (el.textContent || "").trim().slice(0, 80),
          rect: {
            x: Math.round(rect.x),
            y: Math.round(rect.y),
            width: Math.round(rect.width),
            height: Math.round(rect.height),
          },
          styles: {
            display: computed.display,
            color: computed.color,
            backgroundColor: computed.backgroundColor,
            borderColor: computed.borderColor,
            borderRadius: computed.borderRadius,
            padding: computed.padding,
            fontSize: computed.fontSize,
            fontWeight: computed.fontWeight,
            gap: computed.gap,
            width: computed.width,
            height: computed.height,
          },
        });
      });
    }
    return results;
  });

  const stylePath = resolve(outDir, `${outputName}.json`);
  writeFileSync(stylePath, JSON.stringify(styleInfo, null, 2));
  console.log(`📊 Estilos: ${stylePath} (${styleInfo.length} elementos)`);

  // 8. Guardar la URL final (para ver si hubo redirect)
  console.log(`� URL final: ${page.url()}`);

  await browser.close();
  console.log("\n✨ Done.");
}

main().catch((err) => {
  console.error("Fatal:", err);
  process.exit(1);
});
